<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yulgnier.web.app.mapper.GraphInfoMapper">

    <select id="selectGraphVoListByApartmentId" resultType="com.yulgnier.web.app.vo.graph.GraphVo">
        select name, url
        from graph_info
        where item_type = 1
          and item_id = #{apartmentId}
          and is_deleted = 0
    </select>

</mapper>
