<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yulgnier.web.admin.mapper.FeeKeyMapper">

    <resultMap id="FeeKeyVo" type="com.yulgnier.web.admin.vo.fee.FeeKeyVo" autoMapping="true">
        <id property="id" column="id"/>
        <collection property="feeValueList" ofType="com.yulgnier.model.entity.FeeValue">
            <id property="id" column="feeValueId"/>
            <result property="name" column="feeValueName"/>
            <result property="unit" column="unit"/>
            <result property="feeKeyId" column="fee_key_id"/>
        </collection>
    </resultMap>

    <select id="feeInfoList" resultMap="FeeKeyVo">
        select k.id,
               k.name,
               v.id   as feeValueId,
               v.name as feeValueName,
               v.unit,
               v.fee_key_id
        from fee_key k
                 left join fee_value v on k.id = v.fee_key_id and v.is_deleted = 0
        where k.is_deleted = 0;

    </select>
</mapper>